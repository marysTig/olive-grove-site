# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Vite (build-time)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# API (development)
VITE_API_URL="http://localhost:5000/api/v1"

# Cloudinary (server-side uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Admin seed (run once via scripts/seed-admin.ts)
ADMIN_EMAIL="admin@lem3ansra.dz"
ADMIN_PASSWORD="Admin@123456"

# Optional: database password from Supabase dashboard (Database Settings) for npm run setup:db
# SUPABASE_DB_PASSWORD="your-database-password"
# Optional: speeds up setup when direct db.* host is unreachable (e.g. eu-north-1)
# SUPABASE_DB_POOLER_REGION="eu-north-1"
