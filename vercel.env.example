# Vercel deployment environment variables
# Copy these into your Vercel project settings.
# Builds use the Nitro "vercel" preset (see vite.config.ts) so /api/v1 routes
# are handled by the server bundle. Do not set a custom Output Directory in Vercel.

# Runtime (API / server)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Build-time (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional local development override
VITE_API_URL=http://localhost:5000/api/v1
