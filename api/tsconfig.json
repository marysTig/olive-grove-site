{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "../",
    "baseUrl": "../",
    "paths": {
      "@server/*": ["server/src/*"]
    }
  },
  "include": ["./**/*.ts", "../server/src/**/*.ts"],
  "exclude": ["node_modules", "../node_modules"]
}
